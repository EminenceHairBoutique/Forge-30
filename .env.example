# Optional: enables the live AI Coach at /api/coach.
# Without it, Forge30 uses the built-in deterministic mock coach.
# Never expose this to the client — it is read server-side only.
ANTHROPIC_API_KEY=

# --- v3 Phase 1: cloud sync (optional — app runs fully local without these) ---
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=    # server-only; never imported by client code

# --- v3 Phase 2: web push (optional — in-app reminders work without these) ---
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=            # server-only
CRON_SECRET=                  # server-only; Bearer token for /api/cron/notify

# --- v3 Phase 3: native build only ---
NEXT_PUBLIC_API_ORIGIN=       # deployed origin for /api/* in the Capacitor build

# --- v3 Phase 7: subscriptions (optional — no purchase UI without these) ---
# --- Stripe name map: an earlier spec used STRIPE_PLUS_* / NEXT_PUBLIC_APP_URL.
#     This app ships Free/Pro/Elite, so the real names are:
#       STRIPE_PLUS_MONTHLY_PRICE_ID  -> (n/a; there is no Plus tier)
#       STRIPE_PRO_MONTHLY_PRICE_ID   -> STRIPE_PRICE_PRO_MONTHLY (below)
#       STRIPE_PRO_YEARLY_PRICE_ID    -> STRIPE_PRICE_PRO_YEARLY
#       (Elite adds STRIPE_PRICE_ELITE_MONTHLY / _YEARLY)
#       NEXT_PUBLIC_APP_URL           -> NEXT_PUBLIC_API_ORIGIN
STRIPE_SECRET_KEY=            # server-only
STRIPE_WEBHOOK_SECRET=        # server-only
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_PRO_MONTHLY=
STRIPE_PRICE_PRO_YEARLY=
STRIPE_PRICE_ELITE_MONTHLY=
STRIPE_PRICE_ELITE_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_PRO_YEARLY=
NEXT_PUBLIC_STRIPE_PRICE_ELITE_MONTHLY=
NEXT_PUBLIC_STRIPE_PRICE_ELITE_YEARLY=
COACH_MODEL_ELITE=            # optional; default claude-opus-4-8

# --- v3.3 §1.1: rate limiting & the unmetered guard ---
# Self-hosted/personal builds without Supabase: set ALLOW_UNMETERED=true to
# get the quota-free Pro experience. Without it, a backend-less deployment
# treats anonymous callers as free tier with IP-keyed daily limits — an API
# key alone never hands unlimited AI calls to the open internet.
ALLOW_UNMETERED=

# Optional extra allowed browser origins for API routes (comma-separated).
CORS_ALLOWED_ORIGINS=

# --- v3.3 Phase 4: AI feature flags (ship dark; flip = ops, not a rebuild) ---
# Each accepts "true" or "1" to enable; any other value keeps the compiled
# default. Client-visible (NEXT_PUBLIC_) — they gate UI only; the server
# entitlement + rate-limit checks are always authoritative.
NEXT_PUBLIC_FLAG_PHOTO_MEAL=true          # shipped; set false to hide the photo tab
NEXT_PUBLIC_FLAG_TRANSCRIPTION=           # voice-note transcript (needs an STT provider — 501 until then)
NEXT_PUBLIC_FLAG_BLOODWORK_UPLOAD=        # Health bloodwork photo import (Pro)
NEXT_PUBLIC_FLAG_LIFEGRAPH_AI=            # AI narration over deterministic patterns (Pro)
NEXT_PUBLIC_FLAG_RESEARCH_LIVE=           # research mode (Elite)
NEXT_PUBLIC_FLAG_WEARABLES=
NEXT_PUBLIC_FLAG_BARCODE=
NEXT_PUBLIC_FLAG_PSYCHE_REPORT_LIVE=
NEXT_PUBLIC_FLAG_OCR_THREADS=
NEXT_PUBLIC_FLAG_REALTIME_ANALYSIS=
NEXT_PUBLIC_FLAG_LIGHT_MODE=

# Optional: speech-to-text provider selector for /api/journal/transcribe.
# Unset -> the route answers 501 (see DECISIONS §14).
TRANSCRIBE_PROVIDER=
